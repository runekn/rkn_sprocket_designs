{
  "v": "2.0",
  "header": {
    "v": "0.2",
    "name": "HT-I+ 'Super Boxer'",
    "gameVersion": "0.2.50.10",
    "mass": 30701,
    "creationDate": "1942.01.01",
    "class": "",
    "desc": "A regular Boxer taken back to the factory for an uparmoring. The front plate is removed and replaced with an angled one. Tick side-skirts are bolted on to the side. Sections of spare turrets are welded to the front of the turret face. A radio is added to the back. The cannon is removed for slight modifications which allows for use of new modern ammunition. Finally the mantlet backplate is thickened.\n\nThe resulting vehicle is nigh impenetrable by the standards of its day, but is severally underpowered. While upgrades to the cannon helped, the old turret design does not support cannons with higher recoil, so still it lacks firepower compared to its protection.",
    "cost": 26074
  },
