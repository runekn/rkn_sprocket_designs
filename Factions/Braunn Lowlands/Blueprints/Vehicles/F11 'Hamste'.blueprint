{
  "v": "2.0",
  "header": {
    "v": "0.2",
    "name": "F11 'Hamste'",
    "gameVersion": "0.2.50.10",
    "mass": 20121,
    "creationDate": "1940.01.01",
    "class": "",
    "desc": "The army liked the overall design of the F10 but requested a more general purpose tank. And so the engineers went back and redesigned it in to a modern Medium tank designation with large caliber anti-fortification capable main gun. Anti-armor role was covered by replicating HEAT shells from germany. This design became the most numerous during the Braunnic Armament for the entire duration of the war. A sloped rear for the turret is meant to offer only good enough protection to counter AT rifles.",
    "cost": 18040
  },
