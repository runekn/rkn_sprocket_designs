{
  "v": "2.0",
  "header": {
    "v": "0.2",
    "name": "SerTank Model.1930",
    "gameVersion": "0.2.50.10",
    "mass": 29481,
    "creationDate": "1936.01.01",
    "class": "",
    "desc": "The Model.1930, like the 1923, is based on the old WW1 chassis, though much more heavily modified this time. Designed as a moving fortress to break the jungle stalemate that has been the reality of the Groent border dispute, which has seen their opponent fortify key resource nodes within the lighter forested areas. Heavy all-around armor, as well as a main turret allows it to quickly react to amsbushes in the surrounding jungle without having to turn its slow body.",
    "cost": 28266
  },
